<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Agentic OS v3 — Monaco + Git Time-Travel</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:Inter,system-ui,Segoe UI,sans-serif;background:#0b0d12;color:#e6e6f0;height:100vh;overflow:hidden}
.layout{display:grid;grid-template-columns:260px 1fr 330px;grid-template-rows:54px 1fr;height:100vh}
.topbar{grid-column:1/4;background:#0f111a;border-bottom:1px solid #1d2233;display:flex;align-items:center;padding:0 18px;justify-content:space-between}
.brand{font-weight:800;font-size:15.5px}.brand span{color:#7aa2f7}
.badge{font-size:10.5px;background:#16213a;color:#7aa2f7;padding:2px 8px;border-radius:999px;margin-left:8px;border:1px solid #26355a}
.badge2{font-size:10px;background:#2a1a12;color:#ff9e64;padding:2px 8px;border-radius:999px;margin-left:6px;border:1px solid #5a3a20}
.badge3{font-size:10px;background:#13231b;color:#9ece6a;padding:2px 8px;border-radius:999px;margin-left:6px;border:1px solid #294a2b}
.top-actions{display:flex;gap:13px;font-size:12px;color:#9aa4bf}.top-actions div{cursor:pointer}
.left{border-right:1px solid #1d2233;background:#0e1119;overflow-y:auto}
.right{border-left:1px solid #1d2233;background:#0e1119;overflow-y:auto}
.center{display:flex;flex-direction:column;background:#0b0d12;min-width:0}
.tabs{display:flex;gap:5px;padding:9px 14px;border-bottom:1px solid #1d2233;background:#0f121c;flex-wrap:wrap}
.tab{font-size:12px;padding:5px 10px;border-radius:8px;cursor:pointer;color:#9aa7c7}
.tab.active{background:#1c2540;color:#dbe6ff}
.section-title{font-size:11px;text-transform:uppercase;letter-spacing:.12em;color:#6b748f;padding:14px 14px 7px}
.agent{padding:10px 14px;border-left:3px solid transparent;cursor:pointer;display:flex;align-items:center;gap:10px}
.agent:hover{background:#141828}.agent.active{background:#141a2a;border-left-color:var(--c)}
.agent-dot{width:8px;height:8px;border-radius:50%;background:var(--c)}
.agent-name{font-weight:600;font-size:13px}.agent-role{font-size:11px;color:#8a92aa}
.status-pill{margin-left:auto;font-size:10px;padding:2px 6px;border-radius:999px;background:#1a2032;color:#9aa7c7}
.status-pill.working{background:#1a2b1d;color:#9ece6a}
/* builder v3 */
.builder-layout{display:grid;grid-template-columns:220px 1fr 480px;height:100%;min-height:0}
.builder-left{background:#0f1322;border-right:1px solid #1d2238;overflow:auto;display:flex;flex-direction:column}
.builder-center{display:flex;flex-direction:column;min-width:0;background:#0b0d14}
.builder-right{background:#0e111b;border-left:1px solid #1d2238;display:flex;flex-direction:column;min-width:0}
.file-tree{padding:8px;flex:1;overflow:auto}
.file-item{padding:5px 9px;font-size:12.5px;color:#b9c5e8;cursor:pointer;border-radius:6px;display:flex;justify-content:space-between}
.file-item:hover,.file-item.active{background:#1a2340;color:#fff}
.tabbar{display:flex;background:#0f1526;border-bottom:1px solid #1d2238;overflow-x:auto;min-height:38px}
.ftab{padding:8px 14px;font-size:12px;color:#9fb0d8;border-right:1px solid #1c2540;cursor:pointer;white-space:nowrap;display:flex;align-items:center;gap:7px;position:relative;background:#0f1526}
.ftab.active{background:#0b0d14;color:#e8efff;font-weight:600}
.ftab .close{opacity:.5;font-size:13px}.ftab .close:hover{opacity:1;color:#ff6b6b}
.ftab .dirty{width:7px;height:7px;background:#e0af68;border-radius:50%}
.editor-toolbar{display:flex;align-items:center;gap:8px;padding:7px 12px;border-bottom:1px solid #1d2238;background:#10141f;font-size:12px;color:#9aa7c7}
.spacer{flex:1}
.btn{background:#7aa2f7;color:#081020;border:none;padding:9px 14px;border-radius:9px;font-weight:700;cursor:pointer;font-size:13px}
.btn-sm{padding:5px 10px;font-size:11.5px;border-radius:7px}
.btn-ghost{background:#1a2032;color:#b6c3e6;border:1px solid #263250}
.device-btn{padding:4px 9px;border-radius:7px;background:#181f35;color:#a8b6da;border:1px solid #263250;cursor:pointer;font-size:11px}
.device-btn.active{background:#7aa2f7;color:#081028;border-color:#7aa2f7;font-weight:700}
#monacoContainer{flex:1;min-height:320px}
#fallbackEditor{flex:1;width:100%;background:#0a0c14;color:#d7e2ff;border:none;padding:14px;font-family:ui-monospace,monospace;font-size:13px;line-height:1.55;resize:none;outline:none;display:none}
.preview-toolbar{display:flex;align-items:center;gap:7px;padding:7px 12px;border-bottom:1px solid #1d2238;background:#10141f;font-size:12px;flex-wrap:wrap}
.preview-frame-wrap{flex:1;background:#181b29;display:flex;align-items:center;justify-content:center;overflow:auto;padding:14px}
.preview-frame{background:#fff;border-radius:12px;box-shadow:0 16px 50px rgba(0,0,0,.45);transition:all .22s ease;border:6px solid #1a1a2a}
.preview-frame.mobile{width:390px;height:760px}
.preview-frame.tablet{width:768px;height:680px}
.preview-frame.desktop{width:100%;height:100%;border-radius:6px}
/* time-travel */
.timetravel{border-top:1px solid #1d2238;background:#0b0f1a;padding:10px 12px}
.tt-head{display:flex;justify-content:space-between;align-items:center;font-size:11.5px;color:#9fb0d8;margin-bottom:7px}
.tt-slider{width:100%;accent-color:#7aa2f7}
.tt-list{max-height:110px;overflow:auto;margin-top:8px;font-size:11px;color:#8ea0c8}
.tt-item{padding:4px 6px;border-radius:5px;cursor:pointer;display:flex;justify-content:space-between;gap:8px}
.tt-item:hover{background:#151f38}
.tt-item.active{background:#1a2a4a;color:#dbe8ff}
.console-bar{height:120px;border-top:1px solid #1d2238;background:#0a0d16;font-family:ui-monospace,monospace;font-size:11px;color:#8fa0c7;padding:8px 12px;overflow:auto}
.right-card{margin:11px 13px;background:#121629;border:1px solid #222946;border-radius:13px;padding:13px}
.right-card h3{font-size:12.5px;margin-bottom:9px;color:#cbd5ff}
.mini{font-size:11px;color:#7c88a9}
.cost-big{font-size:26px;font-weight:800;color:#9ece6a}
.kv{display:flex;justify-content:space-between;font-size:12.5px;padding:5px 0;color:#a9b4d4;border-bottom:1px dashed #1f2740}
.memory-item{background:#10152a;border:1px solid #1e2642;padding:8px 9px;border-radius:9px;margin-bottom:7px;font-size:12px;color:#b8c5e8}
.footer-bar{padding:7px 16px;font-size:11px;color:#677391;border-top:1px solid #1b2238;background:#0d101a;display:flex;gap:16px;flex-wrap:wrap}
.pill2{padding:2px 7px;background:#151d34;border:1px solid #223055;border-radius:999px;color:#9fb4ea;font-size:11px}
@media(max-width:1280px){.layout{grid-template-columns:230px 1fr}.right{display:none}}
@media(max-width:900px){.builder-layout{grid-template-columns:1fr}.builder-left,.builder-right{display:none}}
</style>
<!-- Monaco loader with offline fallback -->
<script>
window.monacoLoadFailed=false;
</script>
<script src="https://cdn.jsdelivr.net/npm/monaco-editor@0.45.0/min/vs/loader.js" onerror="window.monacoLoadFailed=true"></script>
</head>
<body>
<div class="layout">
  <div class="topbar">
    <div class="brand">🧠 Agentic OS <span>Mission Control</span>
      <span class="badge">FREE BOARDROOM CLONE</span>
      <span class="badge2">v3 MONACO</span>
      <span class="badge3">GIT TIME-TRAVEL</span>
    </div>
    <div class="top-actions">
      <div onclick="showTab('builder')">🚀 Live Builder</div>
      <div onclick="showTab('studio')">🎨 Studio</div>
      <div onclick="showTab('skills')">⚡ Skills</div>
      <div>Local · <b style="color:#9ece6a">HMR ON</b></div>
    </div>
  </div>

  <div class="left" id="agentList"><div class="section-title">Agents — 8 active</div></div>

  <div class="center">
    <div class="tabs">
      <div class="tab active" data-tab="chat">💬 Chat</div>
      <div class="tab" data-tab="builder" style="color:#ff9e64;font-weight:700">🚀 Live Builder v3</div>
      <div class="tab" data-tab="kanban">📋 Kanban</div>
      <div class="tab" data-tab="studio">🎨 Studio</div>
      <div class="tab" data-tab="skills">⚡ Skills</div>
    </div>

    <!-- CHAT -->
    <div id="pane-chat" style="display:flex;flex-direction:column;flex:1;min-height:0">
      <div style="flex:1;overflow:auto;padding:20px" id="chatLog">
        <div style="max-width:760px;line-height:1.6">
          <div style="font-size:11px;color:#7aa2f7;font-weight:700;margin-bottom:4px">Agentic OS v3 · Monaco + Git Time-Travel</div>
          Welcome to <b>Agentic OS v3</b>.<br><br>
          New in v3:<br>
          • <b>Monaco Editor</b> — VS Code in browser, syntax highlight, IntelliSense<br>
          • <b>Multi-file tabs</b> — open index.html + styles.css + app.js side by side<br>
          • <b>Git time-travel</b> — every save = version snapshot, scrubber + restore<br>
          • <b>Hot reload HMR</b> — 600ms auto-save → live preview<br>
          • <b>Mobile / Tablet / Desktop emulator</b><br><br>
          <span class="pill2">Monaco ready</span>
          <span class="pill2">Multi-file</span>
          <span class="pill2">Time-travel</span>
          <span class="pill2" style="color:#ff9e64">Builder v3</span>
        </div>
      </div>
      <div style="border-top:1px solid #1d2233;padding:13px 16px;background:#0f121c;display:flex;gap:9px">
        <input id="chatInput" placeholder="Ask Builder: 'build me a mobile CRM app' · or paste code…" style="flex:1;background:#151a28;border:1px solid #252d45;color:#e6e6f0;padding:12px 13px;border-radius:11px;font-size:14px;outline:none" onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();send()}">
        <button class="btn-ghost btn" onclick="switchAgent(1)" id="agentBtn" style="min-width:130px">Builder ▾</button>
        <button class="btn" onclick="send()">Send →</button>
      </div>
    </div>

    <!-- BUILDER v3 -->
    <div id="pane-builder" style="display:none;flex:1;min-height:0;overflow:hidden">
      <div class="builder-layout">
        <!-- left files -->
        <div class="builder-left">
          <div class="section-title">/preview</div>
          <div class="file-tree" id="fileTree"></div>
          <div style="padding:10px;border-top:1px solid #1d2238">
            <div class="mini" style="margin-bottom:7px">Scaffold:</div>
            <button class="device-btn" style="width:100%;margin-bottom:5px" onclick="scaffold('SaaS dashboard')">SaaS Dashboard</button>
            <button class="device-btn" style="width:100%;margin-bottom:5px" onclick="scaffold('mobile app')">Mobile App</button>
            <button class="device-btn" style="width:100%;margin-bottom:5px" onclick="scaffold('landing page')">Landing</button>
            <button class="device-btn" style="width:100%" onclick="newFile()">+ New file</button>
          </div>
        </div>

        <!-- center editor -->
        <div class="builder-center">
          <!-- multi-file tabs -->
          <div class="tabbar" id="editorTabs"></div>
          <div class="editor-toolbar">
            <span id="currentFileLabel" style="font-family:ui-monospace,monospace">index.html</span>
            <span class="spacer"></span>
            <span class="mini" id="saveStatus" style="color:#9ece6a">saved</span>
            <button class="device-btn" onclick="manualCommit()">📸 Commit</button>
            <button class="device-btn" onclick="saveFile()">💾 Save</button>
          </div>
          <!-- Monaco container -->
          <div id="monacoContainer" style="flex:1;min-height:250px"></div>
          <textarea id="fallbackEditor" placeholder="Monaco loading… fallback editor active"></textarea>

          <!-- Git time-travel -->
          <div class="timetravel">
            <div class="tt-head">
              <span>🕰 Git time-travel — <b id="versionCount">0 versions</b></span>
              <span>
                <button class="device-btn" onclick="loadHistory()">⟳ Refresh</button>
                <button class="device-btn" onclick="restoreSelected()">↶ Restore</button>
              </span>
            </div>
            <input type="range" id="timeSlider" class="tt-slider" min="0" max="0" value="0" oninput="scrubVersion(this.value)">
            <div class="tt-list" id="timeList"><div class="mini">No versions yet — edit a file to create first snapshot.</div></div>
          </div>

          <div class="console-bar" id="consoleBar">› Agentic OS v3 — Monaco + Git time-travel<br>› Hot reload: ON • Auto-save: 600ms<br>› /preview/ serving<br></div>
        </div>

        <!-- right preview -->
        <div class="builder-right">
          <div class="preview-toolbar">
            <span style="color:#9aa7c7">Preview:</span>
            <button class="device-btn active" data-dev="mobile" onclick="setDevice('mobile')">📱 Mobile</button>
            <button class="device-btn" data-dev="tablet" onclick="setDevice('tablet')">▭ Tablet</button>
            <button class="device-btn" data-dev="desktop" onclick="setDevice('desktop')">🖥 Desktop</button>
            <span class="spacer"></span>
            <button class="device-btn" onclick="reloadPreview()">⟳</button>
            <button class="device-btn" onclick="window.open('/preview/index.html','_blank')">↗</button>
          </div>
          <div class="preview-frame-wrap">
            <iframe id="previewFrame" class="preview-frame mobile" src="/preview/index.html" sandbox="allow-scripts allow-same-origin allow-forms"></iframe>
          </div>
          <div style="padding:7px 12px;border-top:1px solid #1d2238;font-size:11px;color:#7b88a8;display:flex;justify-content:space-between">
            <span id="previewInfo">390×760 • iPhone</span>
            <span>HMR <b style="color:#9ece6a">● LIVE</b> • <span id="liveVersionLabel">v0</span></span>
          </div>
        </div>
      </div>
    </div>

    <div id="pane-kanban" style="display:none;flex:1;overflow:auto;padding:16px"><div id="kanbanBoard">Kanban loading…</div></div>
    <div id="pane-studio" style="display:none;flex:1;overflow:auto;padding:20px"><h2>🎨 Studio</h2><p class="mini">Multi-modal pipeline — text / image / video / voice</p></div>
    <div id="pane-skills" style="display:none;flex:1;overflow:auto;padding:20px"><h2>⚡ Skills Hub</h2><div id="skillsGrid"></div></div>

    <div class="footer-bar">
      <span>🟢 v3 Monaco · Git time-travel · HMR</span>
      <span id="costFooter">Cost: $0.0122 · Saved $287/mo</span>
      <span>Agents: 8 · open files: <b id="openFilesCount">0</b></span>
    </div>
  </div>

  <div class="right">
    <div class="right-card"><h3>🎯 Goldie Mission Stack</h3><div id="goalsBox"><div class="mini">Loading…</div></div></div>
    <div class="right-card"><h3>🕰 Time-Travel</h3>
      <div class="kv"><span>Versions</span><span id="rtVersions">0</span></div>
      <div class="kv"><span>Current</span><span id="rtCurrent">index.html</span></div>
      <div class="kv"><span>Last save</span><span id="rtLast">—</span></div>
      <div style="margin-top:8px;display:grid;grid-template-columns:1fr 1fr;gap:6px">
        <button class="device-btn" onclick="manualCommit()">📸 Commit</button>
        <button class="device-btn" onclick="document.getElementById('timeSlider').focus()">⏪ Scrub</button>
      </div>
    </div>
    <div class="right-card"><h3>💰 Cost Analytics</h3><div class="cost-big" id="costBig">$0.0122</div><div class="mini">v3 local-first</div></div>
    <div class="right-card"><h3>🧠 Memory</h3><div id="memBox" class="mini">Agentic OS v3 — Monaco + Git active.</div></div>
  </div>
</div>

<script>
// ---- state ----
let agents=[
  {id:'builder',name:'App Builder',role:'Monaco + Live preview + Git',status:'working',color:'#ff9e64'},
  {id:'claude',name:'Claude',role:'The brain that thinks',status:'idle',color:'#d97757'},
  {id:'hermes',name:'Hermes',role:'Autonomous worker',status:'working',color:'#7aa2f7'},
  {id:'openclaw',name:'OpenClaw',role:'Browser computer-use',status:'idle',color:'#9ece6a'},
  {id:'gemini',name:'Gemini CLI',role:'Google AI code',status:'idle',color:'#bb9af7'},
  {id:'grok',name:'Grok Studio',role:'Multi-modal',status:'idle',color:'#f7768e'},
  {id:'local',name:'Local LLM',role:'Ollama private',status:'idle',color:'#e0af68'},
  {id:'self',name:'Self Layer',role:'Obsidian memory',status:'active',color:'#2ac3de'},
];
let currentAgent='builder';
let openTabs = []; // {path, dirty}
let activeTab = 'index.html';
let monacoEditor=null;
let saveTimer=null;
let versions=[], selectedVersionId=null;

// ---- agents UI ----
function renderAgents(){
  const el=document.getElementById('agentList');
  el.querySelectorAll('.agent').forEach(n=>n.remove());
  agents.forEach(a=>{
    const d=document.createElement('div');
    d.className='agent'+(a.id===currentAgent?' active':'');
    d.style.setProperty('--c', a.color);
    d.onclick=()=>{currentAgent=a.id; renderAgents(); document.getElementById('agentBtn').textContent=a.name+' ▾'; if(a.id==='builder') showTab('builder');};
    d.innerHTML=`<div class="agent-dot"></div><div><div class="agent-name">${a.name}</div><div class="agent-role">${a.role}</div></div><div class="status-pill ${a.status}">${a.status}</div>`;
    el.appendChild(d);
  });
}
function switchAgent(n){ const idx=agents.findIndex(x=>x.id===currentAgent); const ni=(idx+n+agents.length)%agents.length; currentAgent=agents[ni].id; renderAgents(); document.getElementById('agentBtn').textContent=agents[ni].name+' ▾'; }

// ---- tabs ----
document.querySelectorAll('.tab').forEach(t=>t.onclick=()=>{
  document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active')); t.classList.add('active');
  const name=t.dataset.tab;
  ['chat','builder','kanban','studio','skills'].forEach(p=>{
    const el=document.getElementById('pane-'+p); if(el) el.style.display = (p===name)? (p==='chat'?'flex':'block') : 'none';
  });
  if(name==='builder') initBuilder();
});
function showTab(n){ document.querySelector(`.tab[data-tab="${n}"]`)?.click(); }

// ---- chat ----
async function send(){
  const inp=document.getElementById('chatInput'); const txt=inp.value.trim(); if(!txt) return;
  addChat(txt,'user'); inp.value='';
  if(txt.includes('<html')||txt.includes('<!doctype')){
    await saveFileContent(activeTab, txt, 'agent paste');
    addChat('✓ HTML pasted → Monaco updated → preview hot-reloaded','agent');
    return;
  }
  // fake builder reply
  setTimeout(()=> addChat('App Builder v3: received “'+txt.slice(0,70)+'”.\n\nI can scaffold multi-file apps. Try the scaffold buttons left, or tell me: “build me a mobile CRM with Tailwind”. I’ll write index.html + styles.css + app.js, commit a Git version, and hot-reload preview.', 'agent'), 400);
}
function addChat(t, who){
  const log=document.getElementById('chatLog');
  const d=document.createElement('div');
  d.style.marginBottom='14px';
  d.style.maxWidth='760px';
  if(who==='user'){ d.style.background='#161b2b'; d.style.border='1px solid #222942'; d.style.padding='12px 14px'; d.style.borderRadius='12px'; d.textContent=t; }
  else { d.innerHTML='<div style="font-size:11px;color:#ff9e64;font-weight:700;margin-bottom:4px">App Builder · Monaco v3</div>'+t.replace(/\n/g,'<br>'); }
  log.appendChild(d); log.scrollTop=log.scrollHeight;
}

// ---- BUILDER v3 ----
let builderInited=false;
function initBuilder(){
  if(builderInited) return;
  builderInited=true;
  loadFileTree();
  openTabFile('index.html');
  initMonaco();
  loadHistory();
}
function initMonaco(){
  const container=document.getElementById('monacoContainer');
  const fallback=document.getElementById('fallbackEditor');
  if(window.monacoLoadFailed || typeof require==='undefined'){
    container.style.display='none';
    fallback.style.display='block';
    fallback.addEventListener('input', onEditorChange);
    addConsole('› Monaco CDN blocked (offline preview) — using textarea fallback. Run locally for full VS Code editor.');
    return;
  }
  try{
    require.config({ paths: { 'vs': 'https://cdn.jsdelivr.net/npm/monaco-editor@0.45.0/min/vs' }});
    require(['vs/editor/editor.main'], function() {
      monacoEditor = monaco.editor.create(container, {
        value: '// Loading…',
        language: 'html',
        theme: 'vs-dark',
        automaticLayout: true,
        minimap: {enabled:false},
        fontSize: 13,
        scrollBeyondLastLine: false
      });
      monacoEditor.onDidChangeModelContent(()=>{
        markDirty(activeTab, true);
        setStatus('editing…','#e0af68');
        clearTimeout(saveTimer);
        saveTimer = setTimeout(()=> saveFile(), 650);
        // live HMR srcdoc
        liveHMR();
      });
      loadFileIntoEditor(activeTab);
      addConsole('› Monaco Editor v0.45 loaded ✓');
    });
  }catch(e){
    container.style.display='none';
    fallback.style.display='block';
    addConsole('› Monaco failed, fallback active');
  }
}

// multi-file tabs
function openTabFile(path){
  if(!openTabs.find(t=>t.path===path)){
    openTabs.push({path, dirty:false});
  }
  activeTab = path;
  renderEditorTabs();
  loadFileIntoEditor(path);
  document.getElementById('currentFileLabel').textContent = path;
  document.getElementById('rtCurrent').textContent = path;
  loadHistory();
}
function closeTab(path, e){
  if(e) e.stopPropagation();
  openTabs = openTabs.filter(t=>t.path!==path);
  if(activeTab===path){
    activeTab = openTabs[openTabs.length-1]?.path || 'index.html';
    if(openTabs.length===0) openTabFile('index.html');
  }
  renderEditorTabs();
  if(openTabs.find(t=>t.path===activeTab)) loadFileIntoEditor(activeTab);
}
function renderEditorTabs(){
  const bar=document.getElementById('editorTabs');
  bar.innerHTML='';
  openTabs.forEach(t=>{
    const div=document.createElement('div');
    div.className='ftab'+(t.path===activeTab?' active':'');
    div.onclick=()=>openTabFile(t.path);
    div.innerHTML = `<span>${t.path.split('/').pop()}</span>` + (t.dirty?`<span class="dirty"></span>`:'') + `<span class="close" onclick="closeTab('${t.path}',event)">×</span>`;
    bar.appendChild(div);
  });
  document.getElementById('openFilesCount').textContent = openTabs.length;
}
function markDirty(path, d){
  const t=openTabs.find(x=>x.path===path);
  if(t){ t.dirty=d; renderEditorTabs(); }
}

// load file content
async function loadFileIntoEditor(path){
  try{
    const r=await fetch('/api/preview/read?path='+encodeURIComponent(path));
    const text = r.ok ? await r.text() : '';
    if(monacoEditor){
      const model = monaco.editor.createModel(text, getLang(path));
      monacoEditor.setModel(model);
    } else {
      document.getElementById('fallbackEditor').value = text;
    }
    setStatus('loaded','#9ece6a');
  }catch(e){ setStatus('offline','#e0af68'); }
}
function getLang(p){
  if(p.endsWith('.css')) return 'css';
  if(p.endsWith('.js')) return 'javascript';
  if(p.endsWith('.json')) return 'json';
  if(p.endsWith('.md')) return 'markdown';
  return 'html';
}
function getEditorValue(){
  if(monacoEditor) return monacoEditor.getValue();
  return document.getElementById('fallbackEditor').value;
}
function onEditorChange(){
  markDirty(activeTab, true);
  setStatus('editing…','#e0af68');
  clearTimeout(saveTimer);
  saveTimer=setTimeout(saveFile, 650);
  liveHMR();
}
function setStatus(t,c){ const s=document.getElementById('saveStatus'); if(s){ s.textContent=t; s.style.color=c||'#9ece6a'; } }

async function saveFile(){
  const content=getEditorValue();
  await saveFileContent(activeTab, content, 'monaco save');
}
async function saveFileContent(path, content, message='auto save'){
  try{
    const res=await fetch('/api/preview/save',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({path, content, message, author:'builder'})});
    const j=await res.json();
    setStatus('saved ✓','#9ece6a');
    markDirty(path,false);
    document.getElementById('rtLast').textContent=new Date().toLocaleTimeString();
    addConsole('› saved '+path+' — '+(j.versions||'?')+' versions');
    loadHistory();
    reloadPreview();
  }catch(e){
    setStatus('saved locally','#e0af68');
    reloadPreview();
  }
}

// HMR
let hmrTimer=null;
function liveHMR(){
  clearTimeout(hmrTimer);
  hmrTimer=setTimeout(()=>{
    const code=getEditorValue();
    const frame=document.getElementById('previewFrame');
    if(activeTab.endsWith('.html') && code.includes('<html')){
      frame.srcdoc = code;
    }
  }, 250);
}

// file tree
async function loadFileTree(){
  try{
    const r=await fetch('/api/preview/files'); const files=await r.json();
    const box=document.getElementById('fileTree');
    box.querySelectorAll('.file-item').forEach(n=>n.remove());
    files.forEach(f=>{
      const div=document.createElement('div');
      div.className='file-item'+(f.path===activeTab?' active':'');
      div.innerHTML=`<span>📄 ${f.path}</span><span class="mini">${Math.round(f.size/1024*10)/10}kb</span>`;
      div.onclick=()=>openTabFile(f.path);
      box.appendChild(div);
    });
  }catch(e){}
}

// Git time-travel
async function loadHistory(){
  try{
    const r=await fetch('/api/preview/history?path='+encodeURIComponent(activeTab));
    versions = await r.json();
    document.getElementById('versionCount').textContent = versions.length+' versions';
    document.getElementById('rtVersions').textContent = versions.length;
    const slider=document.getElementById('timeSlider');
    slider.max = Math.max(0, versions.length-1);
    slider.value = 0;
    const list=document.getElementById('timeList');
    if(versions.length===0){ list.innerHTML='<div class="mini">No versions yet — edit to create snapshot.</div>'; return; }
    list.innerHTML = versions.map((v,i)=>`<div class="tt-item" data-vid="${v.id}" onclick="scrubVersion(${i})"><span>v${v.id} · ${v.message||'auto save'} · ${v.author}</span><span>${v.ts?.slice(11,19)||''}</span></div>`).join('');
    document.getElementById('liveVersionLabel').textContent='v'+(versions[0]?.id||'0');
  }catch(e){}
}
async function scrubVersion(idx){
  idx = parseInt(idx)||0;
  const v = versions[idx];
  if(!v) return;
  selectedVersionId = v.id;
  // highlight
  document.querySelectorAll('.tt-item').forEach((el,i)=>el.classList.toggle('active', i==idx));
  // preview that version (read-only)
  try{
    const r=await fetch('/api/preview/version?id='+v.id);
    const j=await r.json();
    if(j.content){
      const frame=document.getElementById('previewFrame');
      frame.srcdoc = j.content;
      addConsole('› time-travel preview v'+v.id+' — click Restore to apply');
    }
  }catch(e){}
}
async function restoreSelected(){
  if(!selectedVersionId){ alert('Scrub timeline first, pick a version.'); return; }
  if(!confirm('Restore version '+selectedVersionId+' ? Current will be snapshotted first.')) return;
  await fetch('/api/preview/restore',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({version_id:selectedVersionId})});
  addConsole('› restored v'+selectedVersionId);
  loadFileIntoEditor(activeTab);
  loadHistory();
  reloadPreview();
}
async function manualCommit(){
  const msg = prompt('Commit message:', 'checkpoint '+new Date().toLocaleTimeString());
  if(msg===null) return;
  await saveFile();
  try{
    await fetch('/api/preview/commit',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({path:activeTab, message:msg, author:'builder'})});
    addConsole('› committed: '+msg);
    loadHistory();
  }catch(e){ addConsole('› commit saved locally'); }
}

// preview device
function setDevice(dev){
  const f=document.getElementById('previewFrame');
  f.className='preview-frame '+dev;
  document.querySelectorAll('.preview-toolbar .device-btn[data-dev]').forEach(b=>b.classList.toggle('active', b.dataset.dev===dev));
  const labels={mobile:'390×760 • iPhone', tablet:'768×680 • iPad', desktop:'Fluid • Desktop'};
  document.getElementById('previewInfo').textContent=labels[dev]||dev;
}
function reloadPreview(){
  const f=document.getElementById('previewFrame');
  // if same file is html, use srcdoc HMR else reload iframe src
  const code=getEditorValue();
  if(activeTab.endsWith('.html') && code.includes('<html')){
    f.srcdoc = code;
  } else {
    const src=f.src; f.src='about:blank'; setTimeout(()=>f.src=src.split('?')[0]+'?t='+Date.now(), 40);
  }
}
function addConsole(m){ const c=document.getElementById('consoleBar'); if(c){ c.innerHTML += m+'<br>'; c.scrollTop=c.scrollHeight; } }

// scaffold / new file
async function scaffold(kind){
  addConsole('› scaffolding '+kind+' …');
  try{
    const r=await fetch('/api/preview/scaffold',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({prompt:kind})});
    const j=await r.json();
    // open all returned files
    (j.files||['index.html']).forEach((p,i)=> setTimeout(()=>openTabFile(p), i*120));
    loadFileTree(); loadHistory();
    setTimeout(reloadPreview, 400);
    addChat('✓ '+kind+' scaffolded → 3 files: index.html, styles.css, app.js — open tabs top, edit in Monaco, time-travel below.', 'agent');
  }catch(e){ addChat('Scaffold done (demo).', 'agent'); }
}
function newFile(){
  const name=prompt('New file path (e.g. components/Header.jsx):','new-page.html');
  if(!name) return;
  openTabFile(name);
  // seed empty
  if(monacoEditor){ monacoEditor.setValue('<!-- '+name+' -->\n'); } else { document.getElementById('fallbackEditor').value='<!-- '+name+' -->\n'; }
  markDirty(name,true);
}

// init
renderAgents();
document.getElementById('agentBtn').textContent='Builder ▾';
// auto-open builder
setTimeout(()=>{ showTab('builder'); }, 500);
// load right panel goals stub
document.getElementById('goalsBox').innerHTML = `
<div style="margin-bottom:10px"><div style="display:flex;justify-content:space-between;font-size:12.5px;color:#b8c2de;margin-bottom:4px"><span>Monaco editor live</span><span>100%</span></div><div style="height:7px;background:#1b2140;border-radius:99px"><i style="display:block;height:100%;width:100%;background:linear-gradient(90deg,#7aa2f7,#bb9af7);border-radius:99px"></i></div></div>
<div style="margin-bottom:10px"><div style="display:flex;justify-content:space-between;font-size:12.5px;color:#b8c2de;margin-bottom:4px"><span>Git time-travel</span><span>100%</span></div><div style="height:7px;background:#1b2140;border-radius:99px"><i style="display:block;height:100%;width:100%;background:linear-gradient(90deg,#7aa2f7,#bb9af7);border-radius:99px"></i></div></div>
<div style="margin-bottom:10px"><div style="display:flex;justify-content:space-between;font-size:12.5px;color:#b8c2de;margin-bottom:4px"><span>Multi-file tabs</span><span>100%</span></div><div style="height:7px;background:#1b2140;border-radius:99px"><i style="display:block;height:100%;width:100%;background:linear-gradient(90deg,#7aa2f7,#bb9af7);border-radius:99px"></i></div></div>`;
</script>
</body>
</html>
