# ============================================================
# Agentic OS — Environment Configuration
# Copy this file to .env and fill in your values.
# The Vault UI (🔐 Vault tab) can manage these for you.
# ============================================================

# --- Primary LLM Router ---
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- Optional Direct Provider Keys ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# --- Local LLM (Ollama) ---
# Install: https://ollama.com → then: ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b

# --- Deployment ---
VERCEL_TOKEN=
GITHUB_TOKEN=
CLOUDFLARE_TUNNEL_TOKEN=

# --- Database & Storage ---
# QDRANT_URL=http://localhost:6333   # uncomment if running Qdrant separately

# --- Server ---
# Local-first default: bind to loopback unless remote/container access is intentional.
AGENTIC_OS_PORT=8787
AGENTIC_OS_HOST=127.0.0.1

# --- Security ---
# Secure deployment mode requires a bearer token for API routes.
# Set both values when exposing the service beyond a trusted local machine.
AGENTIC_OS_SECURE_MODE=false
AGENTIC_OS_AUTH_TOKEN=
# Comma-separated browser origins for reverse-proxy/Tauri deployments.
# AGENTIC_OS_ALLOWED_ORIGINS=https://agentic.example.com
# Leave blank to auto-generate on first run.
SECRET_KEY=

# ── Qdrant Vector DB (optional, Sprint 14) ────────────────────────
# Run: docker run -p 6333:6333 qdrant/qdrant
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=  # only needed for Qdrant Cloud

# ── sentence-transformers model (optional) ────────────────────────
# ST_MODEL=all-MiniLM-L6-v2   # default; ~80MB download on first use

# ── Stripe Payments (Sprint 14 deep integration) ──────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Auth providers (Sprint 14) ────────────────────────────────────
# NEXTAUTH_SECRET=your-secret-here
# NEXTAUTH_URL=http://localhost:3000
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# CLERK_SECRET_KEY=
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# AUTH0_DOMAIN=
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
