{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agentic OS",
  "version": "6.0.0",
  "identifier": "com.agenticosvault.app",
  "build": {
    "frontendDist": "../frontend",
    "devUrl": "http://localhost:8787",
    "beforeDevCommand": "python run.py",
    "beforeBuildCommand": "python run.py &"
  },
  "app": {
    "windows": [
      {
        "title": "Agentic OS — Mission Control",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "url": "http://localhost:8787",
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../backend/**", "../frontend/**", "../requirements.txt", "../run.py", "../config.yaml"],
    "externalBin": ["python3", "python"],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": null,
      "signingIdentity": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "linux": {
      "deb": {
        "depends": ["python3", "python3-pip"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}
